    "@tinyclaw/heartware": "workspace:*",
    "@tinyclaw/intercom": "workspace:*",
    "@tinyclaw/learning": "workspace:*",
    "@tinyclaw/logger": "workspace:*",
    "@tinyclaw/matcher": "workspace:*",
    "@tinyclaw/memory": "workspace:*",
    "@tinyclaw/nudge": "workspace:*",
    "@tinyclaw/plugins": "workspace:*",
    "@tinyclaw/plugin-channel-discord": "workspace:*",
    "@tinyclaw/plugin-channel-friends": "workspace:*",
    "@tinyclaw/plugin-provider-gemini": "workspace:*",
    "@tinyclaw/plugin-provider-groq": "workspace:*",
    "@tinyclaw/plugin-provider-openai": "workspace:*",
    "@tinyclaw/plugin-tools-issue-bridge": "workspace:*",
    "@tinyclaw/plugin-tools-memory-core": "workspace:*",
    "@tinyclaw/plugin-tools-context-lossless": "workspace:*",
    "@tinyclaw/plugin-tools-channel-bridge": "workspace:*",
    "@tinyclaw/plugin-tools-project-runner": "workspace:*",
