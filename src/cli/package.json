{
  "name": "tinyclaw",
  "version": "2.0.0",
  "description": "Command-line interface for Tiny Claw",
  "license": "GPL-3.0",
  "author": "Waren Gonzaga",
  "type": "module",
  "bin": {
    "tinyclaw": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warengonzaga/tinyclaw.git",
    "directory": "src/cli"
  },
  "homepage": "https://github.com/warengonzaga/tinyclaw#readme",
  "bugs": {
    "url": "https://github.com/warengonzaga/tinyclaw/issues"
  },
  "keywords": [
    "tinyclaw",
    "ai",
    "agent",
    "cli",
    "companion"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch src/index.ts",
    "start": "bun dist/index.js",
    "test": "bun test"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.0",
    "@tinyclaw/compactor": "workspace:*",
