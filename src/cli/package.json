    "@tinyclaw/secrets": "workspace:*",
    "@tinyclaw/shell": "workspace:*",
    "@tinyclaw/shield": "workspace:*",
    "@tinyclaw/types": "workspace:*",
    "@tinyclaw/web": "workspace:*",
    "@wgtechlabs/log-engine": "^2.3.0",
    "@types/figlet": "^1.7.0",
    "@types/qrcode": "^1.5.6",
